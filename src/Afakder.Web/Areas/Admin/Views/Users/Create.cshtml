@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Yeni Kullanıcı";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Yeni Kullanıcı</h4>
    <a href="/admin/users" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body">
                <form method="post" asp-action="Create" asp-controller="Users" asp-area="Admin">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="fullName" class="form-label fw-semibold">Ad Soyad</label>
                        <input type="text" class="form-control" id="fullName" name="fullName" required />
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label fw-semibold">E-posta</label>
                        <input type="email" class="form-control" id="email" name="email" required />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label fw-semibold">Parola</label>
                        <input type="password" class="form-control" id="password" name="password" required />
                        <div class="form-text">En az 8 karakter, büyük harf, küçük harf ve rakam içermelidir.</div>
                    </div>

                    <div class="mb-3">
                        <label for="role" class="form-label fw-semibold">Rol</label>
                        <select class="form-select" id="role" name="role" required>
                            <option value="">Rol seçin</option>
                            @foreach (SelectListItem item in (SelectList)ViewBag.Roles)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <hr />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-afakder">
                            <i class="bi bi-check-lg"></i> Oluştur
                        </button>
                        <a href="/admin/users" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
