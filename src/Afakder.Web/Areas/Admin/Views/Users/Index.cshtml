@model IEnumerable<ApplicationUser>
@{
    ViewData["Title"] = "Kullanıcılar";
    var userRoles = (Dictionary<string, IList<string>>)ViewBag.UserRoles;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Kullanıcılar</h4>
    <a href="/admin/users/create" class="btn btn-afakder">
        <i class="bi bi-plus-lg"></i> Yeni Kullanıcı
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Roller</th>
                        <th>Kayıt Tarihi</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roles = userRoles.ContainsKey(user.Id) ? userRoles[user.Id] : new List<string>();
                        <tr>
                            <td><strong>@user.FullName</strong></td>
                            <td>@user.Email</td>
                            <td>
                                @foreach (var role in roles)
                                {
                                    <span class="badge bg-primary me-1">@role</span>
                                }
                                @if (!roles.Any())
                                {
                                    <span class="text-muted small">Rol yok</span>
                                }
                            </td>
                            <td>
                                <span class="small text-muted">@user.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                            </td>
                            <td class="text-end">
                                <form method="post" action="/admin/users/delete/@user.Id" class="d-inline"
                                      onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Henüz kullanıcı yok.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
