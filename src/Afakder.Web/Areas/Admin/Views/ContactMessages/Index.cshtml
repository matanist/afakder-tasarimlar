@model IEnumerable<ContactMessage>
@{
    ViewData["Title"] = "İletişim Mesajları";
}

<h4 class="mb-4">İletişim Mesajları</h4>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th></th>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Konu</th>
                        <th>Tarih</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var msg in Model)
                    {
                        <tr class="@(!msg.IsRead ? "table-warning" : "")">
                            <td class="text-center" style="width: 32px;">
                                @if (!msg.IsRead)
                                {
                                    <span class="badge bg-danger" title="Okunmadı">
                                        <i class="bi bi-envelope-fill"></i>
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        <i class="bi bi-envelope-open"></i>
                                    </span>
                                }
                            </td>
                            <td><strong>@msg.Name</strong></td>
                            <td>@msg.Email</td>
                            <td>@msg.Subject</td>
                            <td>
                                <span class="small text-muted">@msg.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</span>
                            </td>
                            <td class="text-end">
                                <a href="/admin/contactmessages/detail/@msg.Id" class="btn btn-sm btn-outline-primary" title="Detay">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form method="post" action="/admin/contactmessages/delete/@msg.Id" class="d-inline"
                                      onsubmit="return confirm('Bu mesajı silmek istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Henüz mesaj yok.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
