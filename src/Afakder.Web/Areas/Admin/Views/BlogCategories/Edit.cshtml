@model IEnumerable<BlogCategory>
@{
    ViewData["Title"] = "Blog Kategorileri";
}

<h4 class="mb-4">Blog Kategorileri</h4>

<div class="row g-4">
    <!-- Add new category form -->
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-plus-circle"></i> Yeni Kategori Ekle
            </div>
            <div class="card-body">
                <form method="post" asp-action="Create" asp-controller="BlogCategories" asp-area="Admin">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="Name" class="form-label fw-semibold">Kategori Adı</label>
                        <input type="text" class="form-control" id="Name" name="Name" required />
                    </div>

                    <div class="mb-3">
                        <label for="Description" class="form-label fw-semibold">Açıklama</label>
                        <textarea class="form-control" id="Description" name="Description" rows="2"></textarea>
                    </div>

                    <div class="mb-3">
                        <label for="SortOrder" class="form-label fw-semibold">Sıra</label>
                        <input type="number" class="form-control" id="SortOrder" name="SortOrder" value="0" />
                    </div>

                    <button type="submit" class="btn btn-afakder">
                        <i class="bi bi-plus-lg"></i> Ekle
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Existing categories list -->
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-folder"></i> Mevcut Kategoriler
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ad</th>
                                <th>Slug</th>
                                <th>Sıra</th>
                                <th class="text-end">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cat in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@cat.Name</strong>
                                        @if (!string.IsNullOrEmpty(cat.Description))
                                        {
                                            <div class="text-muted small">@cat.Description</div>
                                        }
                                    </td>
                                    <td><code>@cat.Slug</code></td>
                                    <td>@cat.SortOrder</td>
                                    <td class="text-end">
                                        <form method="post" action="/admin/blogcategories/delete/@cat.Id" class="d-inline"
                                              onsubmit="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">Henüz kategori eklenmemiş.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
