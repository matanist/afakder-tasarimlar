@model VolunteerApplication
@{
    ViewData["Title"] = "Başvuru Detayı";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Başvuru Detayı</h4>
    <a href="/admin/volunteerapps" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Geri
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Ad Soyad</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3">E-posta</dt>
                    <dd class="col-sm-9">
                        <a href="mailto:@Model.Email">@Model.Email</a>
                    </dd>

                    <dt class="col-sm-3">Telefon</dt>
                    <dd class="col-sm-9">
                        <a href="tel:@Model.Phone">@Model.Phone</a>
                    </dd>

                    <dt class="col-sm-3">Şehir</dt>
                    <dd class="col-sm-9">@Model.City</dd>

                    <dt class="col-sm-3">Tarih</dt>
                    <dd class="col-sm-9">@Model.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Durum</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsRead)
                        {
                            <span class="badge bg-success">Okundu</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Okunmadı</span>
                        }
                    </dd>

                    @if (!string.IsNullOrEmpty(Model.Message))
                    {
                        <dt class="col-sm-3">Mesaj</dt>
                        <dd class="col-sm-9">
                            <div class="p-3 bg-light rounded">@Model.Message</div>
                        </dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">İşlemler</div>
            <div class="card-body">
                <form method="post" action="/admin/volunteerapps/delete/@Model.Id"
                      onsubmit="return confirm('Bu başvuruyu silmek istediğinize emin misiniz?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100">
                        <i class="bi bi-trash"></i> Başvuruyu Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
