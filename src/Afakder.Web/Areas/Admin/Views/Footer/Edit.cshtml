@{
    ViewData["Title"] = "Footer Ayarları";
    var footerLinks = ViewBag.FooterLinks as List<FooterLink> ?? new List<FooterLink>();
    var socialLinks = ViewBag.SocialLinks as List<SocialLink> ?? new List<SocialLink>();
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between">
        <span>Footer Linkleri</span>
    </div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Metin</th>
                    <th>URL</th>
                    <th>Sıra</th>
                    <th>Aktif</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var link in footerLinks)
                {
                    <tr>
                        <td>@link.Text</td>
                        <td>@link.Url</td>
                        <td>@link.SortOrder</td>
                        <td>@(link.IsActive ? "Evet" : "Hayır")</td>
                        <td>
                            <form asp-action="DeleteFooterLink" asp-route-id="@link.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <form asp-action="CreateFooterLink" method="post" class="row g-2 mt-3">
            @Html.AntiForgeryToken()
            <div class="col">
                <input type="text" class="form-control" name="Text" placeholder="Metin" />
            </div>
            <div class="col">
                <input type="text" class="form-control" name="Url" placeholder="URL" />
            </div>
            <div class="col">
                <input type="number" class="form-control" name="SortOrder" placeholder="Sıra" value="0" />
            </div>
            <div class="col">
                <select class="form-select" name="IsActive">
                    <option value="true">Aktif</option>
                    <option value="false">Pasif</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-afakder">Ekle</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between">
        <span>Sosyal Medya Linkleri</span>
    </div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Platform</th>
                    <th>URL</th>
                    <th>Aria Etiketi</th>
                    <th>Sıra</th>
                    <th>Aktif</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var link in socialLinks)
                {
                    <tr>
                        <td>@link.Platform</td>
                        <td>@link.Url</td>
                        <td>@link.AriaLabel</td>
                        <td>@link.SortOrder</td>
                        <td>@(link.IsActive ? "Evet" : "Hayır")</td>
                        <td>
                            <form asp-action="DeleteSocialLink" asp-route-id="@link.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <form asp-action="CreateSocialLink" method="post" class="row g-2 mt-3">
            @Html.AntiForgeryToken()
            <div class="col">
                <input type="text" class="form-control" name="Platform" placeholder="Platform" />
            </div>
            <div class="col">
                <input type="text" class="form-control" name="Url" placeholder="URL" />
            </div>
            <div class="col">
                <textarea class="form-control" name="SvgIcon" placeholder="SVG Ikon" rows="1"></textarea>
            </div>
            <div class="col">
                <input type="text" class="form-control" name="AriaLabel" placeholder="Aria Etiketi" />
            </div>
            <div class="col">
                <input type="number" class="form-control" name="SortOrder" placeholder="Sıra" value="0" />
            </div>
            <div class="col">
                <select class="form-select" name="IsActive">
                    <option value="true">Aktif</option>
                    <option value="false">Pasif</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-afakder">Ekle</button>
            </div>
        </form>
    </div>
</div>
