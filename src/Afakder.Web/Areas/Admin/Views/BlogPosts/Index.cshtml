@model IEnumerable<BlogPost>
@{
    ViewData["Title"] = "Blog Yazıları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">Blog Yazıları</h4>
    <a href="/admin/blogposts/create" class="btn btn-afakder">
        <i class="bi bi-plus-lg"></i> Yeni Yazı
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Başlık</th>
                        <th>Kategori</th>
                        <th>Yazar</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr>
                            <td>
                                <strong>@post.Title</strong>
                                <div class="text-muted small">/@post.Slug</div>
                            </td>
                            <td>@post.Category?.Name</td>
                            <td>@post.Author?.FullName</td>
                            <td>
                                @if (post.IsPublished)
                                {
                                    <span class="badge bg-success">Yayında</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Taslak</span>
                                }
                            </td>
                            <td>
                                <span class="small text-muted">@post.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                            </td>
                            <td class="text-end">
                                <a href="/admin/blogposts/edit/@post.Id" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="/admin/blogposts/delete/@post.Id" class="d-inline"
                                      onsubmit="return confirm('Bu yazıyı silmek istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Henüz yazı eklenmemiş.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
