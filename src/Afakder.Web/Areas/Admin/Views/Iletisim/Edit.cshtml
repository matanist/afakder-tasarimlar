@model IletisimSection
@{
    ViewData["Title"] = "İletişim Bölümü";
    var details = ViewBag.ContactDetails as List<ContactDetail> ?? new List<ContactDetail>();
}

<div class="card mb-4">
    <div class="card-header">İletişim Bölümü Ayarları</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label">Bölüm Etiketi</label>
                <input type="text" class="form-control" asp-for="SectionTag" />
            </div>
            <div class="mb-3">
                <label class="form-label">Başlık</label>
                <input type="text" class="form-control" asp-for="Title" />
            </div>
            <div class="mb-3">
                <label class="form-label">Açıklama</label>
                <textarea class="form-control" asp-for="Description" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Form Başlığı</label>
                <input type="text" class="form-control" asp-for="FormTitle" />
            </div>
            <div class="mb-3">
                <label class="form-label">Gönder Butonu Metni</label>
                <input type="text" class="form-control" asp-for="SubmitButtonText" />
            </div>

            <button type="submit" class="btn btn-afakder">Kaydet</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between">
        <span>İletişim Detayları</span>
    </div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Etiket</th>
                    <th>Değer</th>
                    <th>Sıra</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detail in details)
                {
                    <tr>
                        <td>@detail.Label</td>
                        <td>@detail.Value</td>
                        <td>@detail.SortOrder</td>
                        <td>
                            <form asp-action="DeleteContactDetail" asp-route-id="@detail.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <form asp-action="CreateContactDetail" method="post" class="row g-2 mt-3">
            @Html.AntiForgeryToken()
            <div class="col">
                <input type="text" class="form-control" name="Label" placeholder="Etiket" />
            </div>
            <div class="col">
                <input type="text" class="form-control" name="Value" placeholder="Değer" />
            </div>
            <div class="col">
                <textarea class="form-control" name="SvgIcon" placeholder="SVG Ikon" rows="1"></textarea>
            </div>
            <div class="col">
                <input type="number" class="form-control" name="SortOrder" placeholder="Sıra" value="0" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-afakder">Ekle</button>
            </div>
        </form>
    </div>
</div>
