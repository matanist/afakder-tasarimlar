@model List<NumberBox>
@{
    ViewData["Title"] = "Rakamlar Bölümü";
}

<div class="card">
    <div class="card-header d-flex justify-content-between">
        <span>Rakam Kutuları</span>
    </div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Hedef Değer</th>
                    <th>Etiket</th>
                    <th>Sıra</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TargetValue</td>
                        <td>@item.Label</td>
                        <td>@item.SortOrder</td>
                        <td>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <form asp-action="Create" method="post" class="row g-2 mt-3">
            @Html.AntiForgeryToken()
            <div class="col">
                <textarea class="form-control" name="SvgIcon" placeholder="SVG Ikon" rows="1"></textarea>
            </div>
            <div class="col">
                <input type="number" class="form-control" name="TargetValue" placeholder="Hedef Değer" />
            </div>
            <div class="col">
                <input type="text" class="form-control" name="Label" placeholder="Etiket" />
            </div>
            <div class="col">
                <input type="number" class="form-control" name="SortOrder" placeholder="Sıra" value="0" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-afakder">Ekle</button>
            </div>
        </form>
    </div>
</div>
