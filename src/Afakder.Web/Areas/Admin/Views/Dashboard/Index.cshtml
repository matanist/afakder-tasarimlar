@{
    ViewData["Title"] = "Dashboard";
    var unreadVolunteerApps = (int)(ViewData["UnreadVolunteerApps"] ?? 0);
    var unreadContactMessages = (int)(ViewData["UnreadContactMessages"] ?? 0);
    var publishedPosts = (int)(ViewData["PublishedPosts"] ?? 0);
    var draftPosts = (int)(ViewData["DraftPosts"] ?? 0);
}

<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:rgba(232,115,74,0.12);color:#e8734a;font-size:1.5rem;">
                    <i class="bi bi-person-plus-fill"></i>
                </div>
                <div>
                    <div class="text-muted small">Okunmamış Başvurular</div>
                    <div class="fs-3 fw-bold">@unreadVolunteerApps</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-area="Admin" asp-controller="VolunteerApps" asp-action="Index" class="text-decoration-none small">
                    <i class="bi bi-arrow-right"></i> Tümü
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:rgba(13,110,253,0.12);color:#0d6efd;font-size:1.5rem;">
                    <i class="bi bi-chat-dots-fill"></i>
                </div>
                <div>
                    <div class="text-muted small">Okunmamış Mesajlar</div>
                    <div class="fs-3 fw-bold">@unreadContactMessages</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-area="Admin" asp-controller="ContactMessages" asp-action="Index" class="text-decoration-none small">
                    <i class="bi bi-arrow-right"></i> Tümü
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:rgba(25,135,84,0.12);color:#198754;font-size:1.5rem;">
                    <i class="bi bi-file-earmark-check-fill"></i>
                </div>
                <div>
                    <div class="text-muted small">Yayındaki Yazılar</div>
                    <div class="fs-3 fw-bold">@publishedPosts</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-area="Admin" asp-controller="BlogPosts" asp-action="Index" class="text-decoration-none small">
                    <i class="bi bi-arrow-right"></i> Tümü
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center"
                     style="width:56px;height:56px;background:rgba(255,193,7,0.15);color:#ffc107;font-size:1.5rem;">
                    <i class="bi bi-file-earmark-text-fill"></i>
                </div>
                <div>
                    <div class="text-muted small">Taslak Yazılar</div>
                    <div class="fs-3 fw-bold">@draftPosts</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-0 pt-0">
                <a asp-area="Admin" asp-controller="BlogPosts" asp-action="Index" class="text-decoration-none small">
                    <i class="bi bi-arrow-right"></i> Tümü
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-lightning-fill text-warning"></i> Hızlı Erişim
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <a asp-area="Admin" asp-controller="Hero" asp-action="Edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-star"></i> Hero</a>
                    <a asp-area="Admin" asp-controller="Hikaye" asp-action="Edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-clock-history"></i> Hikaye</a>
                    <a asp-area="Admin" asp-controller="Etki" asp-action="Edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-heart"></i> Etki</a>
                    <a asp-area="Admin" asp-controller="Faaliyetler" asp-action="Edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-grid"></i> Faaliyetler</a>
                    <a asp-area="Admin" asp-controller="Bagis" asp-action="Edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-gift"></i> Bağış</a>
                    <a asp-area="Admin" asp-controller="Gonullu" asp-action="Edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-people"></i> Gönüllü</a>
                    <a asp-area="Admin" asp-controller="Iletisim" asp-action="Edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-envelope"></i> İletişim</a>
                    <a asp-area="Admin" asp-controller="SiteSettings" asp-action="Edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-gear"></i> Site Ayarları</a>
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-person-gear"></i> Kullanıcılar</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-pencil-square text-primary"></i> Blog
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <a asp-area="Admin" asp-controller="BlogPosts" asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil-square"></i> Yazılar</a>
                    <a asp-area="Admin" asp-controller="BlogCategories" asp-action="Edit" class="btn btn-outline-secondary btn-sm"><i class="bi bi-folder"></i> Kategoriler</a>
                </div>
            </div>
        </div>
    </div>
</div>
