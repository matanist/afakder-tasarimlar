@model BagisSection
@{
    ViewData["Title"] = "Bağış Bölümü";
    var cards = ViewBag.ImpactCards as List<ImpactCard> ?? new List<ImpactCard>();
}

<div class="card mb-4">
    <div class="card-header">Bağış Bölümü Ayarları</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label class="form-label">Bölüm Etiketi</label>
                <input type="text" class="form-control" asp-for="SectionTag" />
            </div>
            <div class="mb-3">
                <label class="form-label">Başlık</label>
                <input type="text" class="form-control" asp-for="Title" />
            </div>
            <div class="mb-3">
                <label class="form-label">Başlık Vurgu</label>
                <input type="text" class="form-control" asp-for="TitleHighlight" />
            </div>
            <div class="mb-3">
                <label class="form-label">Açıklama</label>
                <textarea class="form-control" asp-for="Description" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Alt Not</label>
                <input type="text" class="form-control" asp-for="FooterNote" />
            </div>

            <h6 class="text-muted mb-3 mt-4">Kampanya</h6>

            <div class="mb-3">
                <label class="form-label">Kampanya Başlığı</label>
                <input type="text" class="form-control" asp-for="CampaignTitle" />
            </div>
            <div class="mb-3">
                <label class="form-label">Kampanya Hedefi</label>
                <input type="text" class="form-control" asp-for="CampaignTarget" />
            </div>
            <div class="mb-3">
                <label class="form-label">Kampanya İlerleme (%)</label>
                <input type="number" class="form-control" asp-for="CampaignProgress" />
            </div>
            <div class="mb-3">
                <label class="form-label">Kampanya Tutarı</label>
                <input type="text" class="form-control" asp-for="CampaignAmount" />
            </div>
            <div class="mb-3">
                <label class="form-label">Kampanya Notu</label>
                <input type="text" class="form-control" asp-for="CampaignNote" />
            </div>

            <button type="submit" class="btn btn-afakder">Kaydet</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header d-flex justify-content-between">
        <span>Etki Kartları</span>
    </div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr>
                    <th>Tutar</th>
                    <th>Açıklama</th>
                    <th>Öne Çıkan</th>
                    <th>Rozet Metni</th>
                    <th>Sıra</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var card in cards)
                {
                    <tr>
                        <td>@card.Amount</td>
                        <td>@card.Description</td>
                        <td>@(card.IsFeatured ? "Evet" : "Hayır")</td>
                        <td>@card.FeaturedBadgeText</td>
                        <td>@card.SortOrder</td>
                        <td>
                            <form asp-action="DeleteImpactCard" asp-route-id="@card.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <form asp-action="CreateImpactCard" method="post" class="row g-2 mt-3">
            @Html.AntiForgeryToken()
            <div class="col">
                <input type="number" class="form-control" name="Amount" placeholder="Tutar" />
            </div>
            <div class="col">
                <input type="text" class="form-control" name="Description" placeholder="Açıklama" />
            </div>
            <div class="col">
                <select class="form-select" name="IsFeatured">
                    <option value="false">Hayır</option>
                    <option value="true">Evet</option>
                </select>
            </div>
            <div class="col">
                <input type="text" class="form-control" name="FeaturedBadgeText" placeholder="Rozet Metni" />
            </div>
            <div class="col">
                <input type="number" class="form-control" name="SortOrder" placeholder="Sıra" value="0" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-afakder">Ekle</button>
            </div>
        </form>
    </div>
</div>
