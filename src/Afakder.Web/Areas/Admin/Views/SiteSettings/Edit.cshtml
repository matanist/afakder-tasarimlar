@model SiteSetting
@{
    ViewData["Title"] = "Site Ayarları";
}

<div class="card mb-4">
    <div class="card-header">Site Ayarları</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <h6 class="text-muted mb-3">Marka</h6>

            <div class="mb-3">
                <label class="form-label">Logo Metni</label>
                <input type="text" class="form-control" asp-for="LogoText" />
            </div>
            <div class="mb-3">
                <label class="form-label">Logo SVG</label>
                <textarea class="form-control" asp-for="LogoSvg" rows="4"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Footer Slogan</label>
                <input type="text" class="form-control" asp-for="FooterTagline" />
            </div>
            <div class="mb-3">
                <label class="form-label">Footer Motto</label>
                <input type="text" class="form-control" asp-for="FooterMotto" />
            </div>
            <div class="mb-3">
                <label class="form-label">Preloader Metni</label>
                <input type="text" class="form-control" asp-for="PreloaderText" />
            </div>
            <div class="mb-3">
                <label class="form-label">Acil Durum Numarası</label>
                <input type="text" class="form-control" asp-for="EmergencyNumber" />
            </div>
            <div class="mb-3">
                <label class="form-label">Acil Durum Metni</label>
                <input type="text" class="form-control" asp-for="EmergencyText" />
            </div>
            <div class="mb-3">
                <label class="form-label">Telif Hakkı</label>
                <input type="text" class="form-control" asp-for="Copyright" />
            </div>

            <h6 class="text-muted mb-3 mt-4">SEO</h6>

            <div class="mb-3">
                <label class="form-label">Varsayılan Sayfa Başlığı</label>
                <input type="text" class="form-control" asp-for="DefaultPageTitle" />
            </div>
            <div class="mb-3">
                <label class="form-label">Varsayılan Meta Açıklaması</label>
                <textarea class="form-control" asp-for="DefaultMetaDescription" rows="3"></textarea>
            </div>

            <h6 class="text-muted mb-3 mt-4">Navigasyon CTA</h6>

            <div class="mb-3">
                <label class="form-label">Nav CTA Metni</label>
                <input type="text" class="form-control" asp-for="NavCtaText" />
            </div>
            <div class="mb-3">
                <label class="form-label">Nav CTA URL</label>
                <input type="text" class="form-control" asp-for="NavCtaUrl" />
            </div>

            <button type="submit" class="btn btn-afakder">Kaydet</button>
        </form>
    </div>
</div>
