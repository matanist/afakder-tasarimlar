@model HikayeViewModel

<section id="hikaye" class="section section-response">
  <div class="container">
    <div class="response-header">
      <span class="section-tag">@Model.Section.SectionTag</span>
      <h2 class="mega-number">@Model.Section.MegaNumber <span class="mega-unit">@Model.Section.MegaUnit</span></h2>
      <p class="response-subtitle">@Html.Raw(Model.Section.Subtitle)</p>
    </div>
    <div class="timeline-cards">
      @foreach (var card in Model.TimelineCards)
      {
          <div class="timeline-card" data-animate>
            <div class="timeline-badge">
              <span class="timeline-hour">@card.HourRange</span>
              <span class="timeline-label">@card.HourLabel</span>
            </div>
            <div class="timeline-content">
              <h3>@card.Title</h3>
              <p>@card.Description</p>
              <div class="timeline-icon">
                @Html.Raw(card.SvgIcon)
              </div>
            </div>
          </div>
      }
    </div>
  </div>
</section>
