@model IletisimViewModel

<section id="iletisim" class="section section-contact">
  <div class="container">
    <div class="contact-wrapper">
      <div class="contact-info">
        <span class="section-tag">@Model.Section.SectionTag</span>
        <h2 class="section-title">@Model.Section.Title</h2>
        <p class="contact-desc">@Model.Section.Description</p>
        <div class="contact-details">
          @foreach (var detail in Model.ContactDetails)
          {
              <div class="contact-item">
                <div class="contact-icon">
                  @Html.Raw(detail.SvgIcon)
                </div>
                <div>
                  <strong>@detail.Label</strong>
                  <p>@Html.Raw(detail.Value)</p>
                </div>
              </div>
          }
        </div>
      </div>
      <div class="contact-form-wrapper">
        <form id="contactForm" class="warm-form" asp-controller="Form" asp-action="Iletisim" method="post" novalidate>
          @Html.AntiForgeryToken()
          <h3 class="form-title">@Model.Section.FormTitle</h3>
          <div class="form-group">
            <label for="cName">Adınız</label>
            <input type="text" id="cName" name="Name" placeholder="Adınızı yazın..." required>
            <span class="form-error"></span>
          </div>
          <div class="form-group">
            <label for="cEmail">E-posta</label>
            <input type="email" id="cEmail" name="Email" placeholder="ornek@email.com" required>
            <span class="form-error"></span>
          </div>
          <div class="form-group">
            <label for="cSubject">Konu</label>
            <input type="text" id="cSubject" name="Subject" placeholder="Mesajınızın konusu" required>
            <span class="form-error"></span>
          </div>
          <div class="form-group">
            <label for="cMessage">Mesajınız</label>
            <textarea id="cMessage" name="Message" rows="4" placeholder="Mesajınızı buraya yazın..." required></textarea>
            <span class="form-error"></span>
          </div>
          <button type="submit" class="btn btn-primary btn-full">@Model.Section.SubmitButtonText</button>
        </form>
      </div>
    </div>
  </div>
</section>
