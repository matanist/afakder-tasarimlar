@model HeroViewModel

<section id="hero" class="hero">
  <div class="hero-bg">
    <div class="particle" style="--x: 10%; --delay: 0s; --duration: 8s; --size: 4px; --opacity: 0.6;"></div>
    <div class="particle" style="--x: 20%; --delay: 1.2s; --duration: 10s; --size: 3px; --opacity: 0.4;"></div>
    <div class="particle" style="--x: 30%; --delay: 0.5s; --duration: 7s; --size: 5px; --opacity: 0.7;"></div>
    <div class="particle" style="--x: 40%; --delay: 2s; --duration: 9s; --size: 3px; --opacity: 0.5;"></div>
    <div class="particle" style="--x: 50%; --delay: 0.8s; --duration: 11s; --size: 6px; --opacity: 0.8;"></div>
    <div class="particle" style="--x: 60%; --delay: 1.5s; --duration: 8s; --size: 4px; --opacity: 0.6;"></div>
    <div class="particle" style="--x: 70%; --delay: 3s; --duration: 10s; --size: 3px; --opacity: 0.4;"></div>
    <div class="particle" style="--x: 80%; --delay: 0.3s; --duration: 7s; --size: 5px; --opacity: 0.7;"></div>
    <div class="particle" style="--x: 90%; --delay: 2.5s; --duration: 9s; --size: 4px; --opacity: 0.5;"></div>
    <div class="particle" style="--x: 15%; --delay: 1s; --duration: 12s; --size: 3px; --opacity: 0.3;"></div>
    <div class="particle" style="--x: 25%; --delay: 3.5s; --duration: 8s; --size: 6px; --opacity: 0.6;"></div>
    <div class="particle" style="--x: 35%; --delay: 0.7s; --duration: 10s; --size: 4px; --opacity: 0.5;"></div>
    <div class="particle" style="--x: 45%; --delay: 2.2s; --duration: 9s; --size: 3px; --opacity: 0.4;"></div>
    <div class="particle" style="--x: 55%; --delay: 1.8s; --duration: 7s; --size: 5px; --opacity: 0.7;"></div>
    <div class="particle" style="--x: 65%; --delay: 0.4s; --duration: 11s; --size: 4px; --opacity: 0.6;"></div>
    <div class="particle" style="--x: 75%; --delay: 2.8s; --duration: 8s; --size: 3px; --opacity: 0.5;"></div>
    <div class="particle" style="--x: 85%; --delay: 1.3s; --duration: 10s; --size: 5px; --opacity: 0.4;"></div>
    <div class="particle" style="--x: 5%; --delay: 3.2s; --duration: 9s; --size: 4px; --opacity: 0.6;"></div>
    <div class="particle" style="--x: 95%; --delay: 0.6s; --duration: 7s; --size: 6px; --opacity: 0.8;"></div>
    <div class="particle" style="--x: 48%; --delay: 1.7s; --duration: 12s; --size: 3px; --opacity: 0.3;"></div>
    <div class="ecg-container">
      <svg class="ecg-line" viewBox="0 0 1200 100" preserveAspectRatio="none">
        <path class="ecg-path" d="M0,50 L200,50 L220,50 L230,20 L240,80 L250,10 L260,90 L270,50 L290,50 L500,50 L520,50 L530,20 L540,80 L550,10 L560,90 L570,50 L590,50 L800,50 L820,50 L830,20 L840,80 L850,10 L860,90 L870,50 L890,50 L1100,50 L1120,50 L1130,20 L1140,80 L1150,10 L1160,90 L1170,50 L1200,50"/>
      </svg>
    </div>
  </div>
  <div class="hero-content">
    <h1 class="hero-title animate-in">@Model.Section.TitleLine1<br><span class="highlight">@Model.Section.TitleHighlight</span></h1>
    <p class="hero-subtitle animate-in">@Html.Raw(Model.Section.Subtitle)</p>
    <div class="hero-actions animate-in">
      <a href="@Model.Section.PrimaryCtaUrl" class="btn btn-primary btn-glow">@Model.Section.PrimaryCtaText</a>
      <a href="@Model.Section.SecondaryCtaUrl" class="btn btn-outline">@Model.Section.SecondaryCtaText</a>
    </div>
  </div>
  <div class="stats-ribbon">
    @for (int i = 0; i < Model.Stats.Count; i++)
    {
        <div class="stat-item">
          <span class="stat-number">@Model.Stats[i].Value</span>
          <span class="stat-label">@Model.Stats[i].Label</span>
        </div>
        if (i < Model.Stats.Count - 1)
        {
            <div class="stat-divider"></div>
        }
    }
  </div>
</section>
